rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                    && (
                      request.auth.token.admin == true
                      || request.auth.token.email == 'admin@testt.com'
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
                    );
    }
  }
}
