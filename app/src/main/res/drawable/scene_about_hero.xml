<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#D7D7D7"
                android:startColor="#F3F3F3" />
        </shape>
    </item>

    <item android:left="18dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8E8E8" />
        </shape>
    </item>

    <item android:left="82dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#E2E2E2" />
        </shape>
    </item>

    <item android:right="42dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#DCDCDC" />
        </shape>
    </item>

    <item android:left="0dp" android:right="0dp" android:bottom="0dp" android:top="322dp">
        <shape android:shape="rectangle">
            <solid android:color="#C9C9C9" />
        </shape>
    </item>

    <item android:width="92dp" android:height="24dp" android:gravity="bottom|center_horizontal" android:bottom="28dp">
        <shape android:shape="oval">
            <solid android:color="#A9A9A9" />
        </shape>
    </item>

    <item android:width="108dp" android:height="165dp" android:gravity="bottom|center_horizontal" android:bottom="50dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#121212" />
        </shape>
    </item>

    <item android:width="34dp" android:height="34dp" android:gravity="bottom|center_horizontal" android:bottom="195dp">
        <shape android:shape="oval">
            <solid android:color="#121212" />
        </shape>
    </item>

    <item android:width="24dp" android:height="100dp" android:gravity="bottom|center_horizontal" android:bottom="8dp" android:left="28dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#141414" />
        </shape>
    </item>

    <item android:width="24dp" android:height="100dp" android:gravity="bottom|center_horizontal" android:bottom="8dp" android:right="28dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#141414" />
        </shape>
    </item>

    <item android:width="74dp" android:height="20dp" android:gravity="bottom|center_horizontal" android:bottom="184dp">
        <shape android:shape="rectangle">
            <solid android:color="#121212" />
        </shape>
    </item>

    <item android:width="2dp" android:height="92dp" android:gravity="bottom|center_horizontal" android:bottom="36dp" android:left="0dp">
        <rotate android:fromDegrees="23" android:toDegrees="23">
            <shape android:shape="rectangle">
                <solid android:color="#242424" />
            </shape>
        </rotate>
    </item>

    <item android:width="2dp" android:height="92dp" android:gravity="bottom|center_horizontal" android:bottom="36dp" android:right="0dp">
        <rotate android:fromDegrees="-23" android:toDegrees="-23">
            <shape android:shape="rectangle">
                <solid android:color="#242424" />
            </shape>
        </rotate>
    </item>
</layer-list>
