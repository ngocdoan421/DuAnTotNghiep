<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trend_bg"
    android:fillViewport="true"
    android:paddingBottom="96dp"
    tools:context=".AboutFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvAboutHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="‹ GIỚI THIỆU TRENDIFY ⌂"
                android:textColor="@color/trend_text"
                android:textSize="14sp"
                android:textStyle="normal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvAboutBag"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvAboutBag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="👜"
                android:textColor="@color/trend_text"
                android:textSize="18sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="420dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/scene_about_hero" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="TRENDIFY EXCELLENCE"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="NGHỆ THUẬT\nTUYỂN CHỌN"
                        android:textColor="@android:color/white"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp"
                        android:paddingTop="6dp" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:gravity="center"
            android:lineSpacingExtra="5dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="22dp"
            android:text="&quot;Khởi nguồn là tâm điểm của thời trang thế giới, Trendify không chỉ là một ứng dụng, đó là một không gian trải nghiệm lãng mạn thuật đẳng cho những người yêu cái đẹp hiện đại.&quot;"
            android:textColor="@color/trend_text"
            android:textSize="15sp"
            android:textStyle="italic" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/scene_about_lines" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="DẤU ẤN CỦA CHÚNG TÔI"
            android:textAllCaps="true"
            android:textColor="@color/trend_gold"
            android:textSize="11sp"
            android:letterSpacing="0.12" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:paddingTop="6dp"
            android:text="Câu chuyện của chúng tôi"
            android:textColor="@color/trend_text"
            android:textSize="24sp"
            android:textStyle="normal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="5dp"
            android:paddingTop="10dp"
            android:text="Trendy được thành lập với niềm tin rằng thời trang là một hình thức biểu đạt bản thân cao quý nhất. Chúng tôi không chỉ hướng chọn những xu hướng thời trang đương đại, mà tập trung vào những giá trị tinh thần và sắc gọn từ thanh lịch, tinh mới đến những cách đánh bộ cấ n bản."
            android:textColor="@color/trend_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:paddingTop="28dp"
            android:text="Tầm nhìn &amp; Sứ mệnh"
            android:textColor="@color/trend_text"
            android:textSize="23sp"
            android:textStyle="normal" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/trend_card"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/trend_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦"
                    android:textColor="@color/trend_gold"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:paddingTop="8dp"
                    android:text="TÁI ĐỊNH NGHĨA MUA SẮM"
                    android:textColor="@color/trend_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:paddingTop="6dp"
                    android:text="Kết nối trải nghiệm mua sắm cá nhân hóa, nơi công nghệ hiện đại gặp gỡ vẻ đẹp tinh tế."
                    android:textColor="@color/trend_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/trend_card_dark"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thẩm mỹ Tuyệt đối"
                    android:textColor="@android:color/white"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:paddingTop="8dp"
                    android:text="Chúng tôi không chỉ chọn lọc sản phẩm, chúng tôi bền bỉ xây dựng cách đón đợi một chuẩn mực sang trọng, tinh gọn."
                    android:textColor="#F0F0F0"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/trend_card"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/trend_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◌"
                    android:textColor="@color/trend_gold"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:paddingTop="8dp"
                    android:text="KẾT NỐI TOÀN CẦU"
                    android:textColor="@color/trend_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:paddingTop="6dp"
                    android:text="Mang những điều xa xỉ đến gần nhất thể giợi đằng nhấn vật mỗi dòng bước qua thế giới thời trang chuẩn mực."
                    android:textColor="@color/trend_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/scene_policy_boutique" />
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="@color/trend_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Phát triển Bền vững"
            android:textColor="@color/trend_text"
            android:textSize="23sp"
            android:textStyle="normal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="5dp"
            android:paddingTop="10dp"
            android:text="&quot;Sự sang trọng không thể tách rời khỏi trách nhiệm. Chúng tôi cam kết bảo toàn vẻ đẹp của hành tinh thông qua thời trang và cảm hứng.&quot;"
            android:textColor="@color/trend_muted"
            android:textSize="14sp"
            android:textStyle="italic" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="5dp"
            android:paddingTop="12dp"
            android:text="Trendify ưu tiên hợp tác với các nhà thiết kế sử dụng vật liệu tái chế, quy trình sản xuất thân thiện với môi trường, đảm bảo mỗi sản phẩm bạn sở hữu đều mang một giá trị nhân văn sâu sắc."
            android:textColor="@color/trend_muted"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/trend_card_dark"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Đặc quyền\nConcierge"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:paddingTop="8dp"
                    android:text="Đội ngũ chuyên gia phong cách cá nhân của chúng tôi luôn sẵn sàng hỗ trợ bạn tìm kiếm những món đồ hoàn hảo với bất kỳ đón nhanh nào hoặc một sản phẩm cho riêng bạn."
                    android:textColor="#F1F1F1"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@android:color/white"
                    android:text="LIÊN HỆ CHUYÊN GIA"
                    android:textAllCaps="false"
                    android:textColor="@color/trend_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
