<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Search Bar -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_pill"
            android:hint="Tìm sản phẩm..."
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textSize="14sp"
            android:textColorHint="#999999"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/etSearch" />

        <!-- Recent Searches -->
        <TextView
            android:id="@+id/tvRecent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TÌM KIẾM GẦN ĐÂY"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/llRecentSearches"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvRecent">

            <!-- Mock Item 1 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Váy đen"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_centerVertical="true" />
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_close"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#AAAAAA"/>
            </RelativeLayout>

            <!-- Mock Item 2 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giày trắng"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_centerVertical="true" />
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_close"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#AAAAAA"/>
            </RelativeLayout>

            <!-- Mock Item 3 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Áo khoác denim"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_centerVertical="true" />
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_close"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#AAAAAA"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- Trending -->
        <TextView
            android:id="@+id/tvTrending"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ĐANG XU HƯỚNG"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/llRecentSearches"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTrending">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Váy hè"
                android:textColor="@color/black"
                app:chipBackgroundColor="#F5F5F5"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giày thể thao"
                android:textColor="@color/black"
                app:chipBackgroundColor="#F5F5F5"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Túi xách"
                android:textColor="@color/black"
                app:chipBackgroundColor="#F5F5F5"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kính mát"
                android:textColor="@color/black"
                app:chipBackgroundColor="#F5F5F5"
                app:chipStrokeWidth="0dp" />

        </com.google.android.material.chip.ChipGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
