<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/trend_bg"
    tools:context=".AddressManagementActivity">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/trend_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:contentDescription="Quay lại"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/trend_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Địa chỉ giao hàng"
            android:textColor="@color/trend_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        android:paddingBottom="108dp"
        app:layout_constraintBottom_toTopOf="@id/bottomAction"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DANH SÁCH ĐỊA CHỈ"
                android:textColor="@color/trend_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHomeAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_text"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/trend_text" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Nhà riêng"
                            android:textColor="@color/trend_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@color/trend_text"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:text="Mặc định"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvHomeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Lê Tuấn Anh"
                        android:textColor="@color/trend_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHomePhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="098xxxxxxx"
                        android:textColor="@color/trend_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvHomeDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="3dp"
                        android:text="123 Nguyễn Trãi, Thanh Xuân, Hà Nội"
                        android:textColor="@color/trend_muted"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditHome"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/trend_card"
                            android:text="Sửa"
                            android:textColor="@color/trend_text"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDeleteHome"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/trend_card"
                            android:text="Xóa"
                            android:textColor="@color/trend_text"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOfficeAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/trend_muted" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Văn phòng"
                            android:textColor="@color/trend_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvOfficeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Lê Tuấn Anh"
                        android:textColor="@color/trend_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOfficePhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="098xxxxxxx"
                        android:textColor="@color/trend_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvOfficeDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="3dp"
                        android:text="45 Lê Lợi, Quận 1, Thành phố Hồ Chí Minh"
                        android:textColor="@color/trend_muted"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditOffice"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/trend_card"
                            android:text="Sửa"
                            android:textColor="@color/trend_text"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSetOfficeDefault"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1.5"
                            android:backgroundTint="@color/trend_card"
                            android:text="Mặc định"
                            android:textColor="@color/trend_text"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDeleteOffice"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/trend_card"
                            android:text="Xóa"
                            android:textColor="@color/trend_text"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFamilyAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="@color/trend_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/trend_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/trend_muted" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="Nhà bố mẹ"
                            android:textColor="@color/trend_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFamilyName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Lê Minh Hoàng"
                        android:textColor="@color/trend_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFamilyPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="091xxxxxxx"
                        android:textColor="@color/trend_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvFamilyDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:lineSpacingExtra="3dp"
                        android:text="78 Trần Hưng Đạo, Hoàn Kiếm, Hà Nội"
                        android:textColor="@color/trend_muted"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditFamily"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/trend_card"
                            android:text="Sửa"
                            android:textColor="@color/trend_text"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSetFamilyDefault"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1.5"
                            android:backgroundTint="@color/trend_card"
                            android:text="Mặc định"
                            android:textColor="@color/trend_text"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDeleteFamily"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/trend_card"
                            android:text="Xóa"
                            android:textColor="@color/trend_text"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/trend_border"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomAction"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:background="@color/trend_card"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddAddress"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/trend_text"
            android:text="THÊM ĐỊA CHỈ MỚI"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_plus"
            app:iconTint="@android:color/white" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
