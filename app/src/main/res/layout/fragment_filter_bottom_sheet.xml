<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <TextView
            android:id="@+id/tvFilterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bộ Lọc"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/ivCloseFilter"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:layout_marginEnd="20dp"
            android:tint="@color/black"
            app:layout_constraintTop_toTopOf="@id/tvFilterTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvFilterTitle"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/dividerHeader"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvFilterTitle" />

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constrainedHeight="true"
            app:layout_constraintTop_toBottomOf="@id/dividerHeader"
            app:layout_constraintBottom_toTopOf="@id/bottomLayout"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Khoảng Giá -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khoảng Giá"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:hint="Tối thiểu"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:inputType="number" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:hint="Tối đa"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:inputType="number" />
                </LinearLayout>

                <!-- Kích Cỡ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kích Cỡ"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="XS"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="S"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="M"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_chip_selected"
                        android:layout_marginEnd="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="L"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:text="XL"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected" />
                </LinearLayout>

                <!-- Màu Sắc -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Màu Sắc"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_black"
                        android:layout_marginEnd="12dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_white"
                        android:layout_marginEnd="12dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_grey"
                        android:layout_marginEnd="12dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_blue"
                        android:layout_marginEnd="12dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_red" />
                </LinearLayout>

                <!-- Sắp Xếp Theo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sắp Xếp Theo"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Phổ biến"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Mới nhất"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Giá: Thấp đến cao"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Giá: Cao đến thấp"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:textColor="@color/black"
                        android:background="@drawable/bg_chip_unselected" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- Bottom Layout -->
        <LinearLayout
            android:id="@+id/bottomLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Áp Dụng"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/black"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
